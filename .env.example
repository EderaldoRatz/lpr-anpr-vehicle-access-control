# LPR/ANPR Vehicle Access Control - Environment Configuration
# Copy this file to .env and configure with your values

# ======================
# DATABASE CONFIGURATION
# ======================
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/lpr_anpr_db
DATABASE_ENGINE=mysql  # Options: mysql, postgresql, sqlite
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=lpr_anpr_db

# ======================
# API CONFIGURATION
# ======================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true
ENVIRONMENT=development  # Options: development, staging, production

# ======================
# SECURITY CONFIGURATION
# ======================
SECRET_KEY=your-super-secret-key-change-in-production
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30
REFRESH_TOKEN_EXPIRATION_DAYS=7
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_CREDENTIALS=true

# ======================
# LPR/ANPR CONFIGURATION
# ======================
# YOLO Model
YOLO_MODEL=yolov5s  # Options: yolov5s, yolov5m, yolov5l, yolov5x
YOLO_CONFIDENCE=0.5
YOLO_IOU=0.45

# OCR Configuration
OCR_ENGINE=easyocr  # Options: easyocr, tesseract
TESSERACT_PATH=/usr/bin/tesseract  # Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
EASYOCR_LANGUAGES=en,pt  # Portuguese and English

# Plate Recognition
PLATE_MIN_WIDTH=50
PLATE_MIN_HEIGHT=20
PLATE_CONFIDENCE_THRESHOLD=0.6

# ======================
# CAMERA CONFIGURATION
# ======================
# Main camera (0 = webcam, or IP address)
CAMERA_MAIN=0
CAMERA_MAIN_FPS=30
CAMERA_MAIN_RESOLUTION=1280x720

# Additional cameras
CAMERA_2_ENABLED=false
CAMERA_2_URL=rtsp://camera2_ip:554/stream

# ======================
# HARDWARE CONFIGURATION
# ======================
# Serial Communication
SERIAL_PORT=/dev/ttyUSB0  # Windows: COM3
SERIAL_BAUDRATE=9600
SERIAL_TIMEOUT=2

# MQTT Configuration
MQTT_ENABLED=false
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USER=mqtt_user
MQTT_PASSWORD=mqtt_password
MQTT_TOPIC_GATE=home/gate/control
MQTT_TOPIC_SENSOR=home/gate/sensor

# Gate Control
GATE_RELAY_PIN=5
GATE_OPEN_DURATION=5  # seconds
GATE_SENSOR_PIN=6
GATE_SENSOR_INVERT=false

# ======================
# NOTIFICATION CONFIGURATION
# ======================
NOTIFICATION_ENABLED=true
NOTIFICATION_METHOD=email  # Options: email, whatsapp, both

# Email Configuration
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_USE_TLS=true

# WhatsApp Configuration (Twilio)
WHATSAPP_ENABLED=false
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=+1234567890
NOTIFICATION_PHONE=+5511999999999

# ======================
# LOGGING CONFIGURATION
# ======================
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/application.log
LOG_MAX_SIZE=10485760  # 10MB
LOG_BACKUP_COUNT=5
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ======================
# FILE STORAGE CONFIGURATION
# ======================
UPLOAD_DIRECTORY=./uploads
CAPTURED_IMAGES_DIRECTORY=./uploads/captured_images
EVIDENCE_DIRECTORY=./uploads/evidence
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,gif

# ======================
# BACKUP CONFIGURATION
# ======================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Cron expression (2 AM daily)
BACKUP_DIRECTORY=./backups
BACKUP_RETENTION_DAYS=30

# ======================
# PERFORMANCE CONFIGURATION
# ======================
CACHE_ENABLED=true
CACHE_TYPE=memory  # Options: memory, redis
CACHE_TTL=300  # seconds
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60  # seconds

# ======================
# REPORT CONFIGURATION
# ======================
REPORT_FOOTER_TEXT=Vehicle Access Control System
COMPANY_NAME=Your Company Name
COMPANY_LOGO=./assets/logo.png

# ======================
# FRONTEND CONFIGURATION (for docker-compose)
# ======================
REACT_APP_API_URL=http://localhost:8000/api
REACT_APP_API_TIMEOUT=30000
